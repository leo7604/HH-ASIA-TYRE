# Google Analytics 4 Measurement ID
# Get this from GA4 Admin > Data Streams > Web stream > Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA4_ID=G-XXXXXXXXXX

# API Configuration
# Base URL for your backend API (database integration)
VITE_API_BASE_URL=https://hh-asia-tyre-crm-inv-sys.vercel.app/api

# Database Configuration (for future use)
# VITE_DB_TYPE=postgresql|mysql|mongodb
# VITE_DB_HOST=localhost
# VITE_DB_PORT=5432
# VITE_DB_NAME=hh_asia_tyre
# VITE_DB_USER=your_db_user
# VITE_DB_PASSWORD=your_db_password

# Feature Flags
# Set to 'true' to enable database mode, 'false' for localStorage only
VITE_USE_DATABASE=true
VITE_ENABLE_FALLBACK=true
