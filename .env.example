# ============================================
# HH Asia Tyre - Environment Variables
# ============================================
# 
# INSTRUCTIONS:
# 1. Replace the placeholder values below with your ACTUAL Supabase credentials
# 2. Get these from: Supabase Dashboard → Project Settings → API
# 3. Save this file as: .env (in hh-asia-tyre-prototype folder)
# 4. NEVER commit this file to Git! (it's in .gitignore)
#
# ============================================

# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Your Supabase Project URL
# Format: https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key
# This is SAFE to use in frontend (not the service_role key!)
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Your app name
VITE_APP_NAME=HH Asia Tyre

# Your app URL (development)
VITE_APP_URL=http://localhost:5173

# Your app URL (production - uncomment when deployed)
# VITE_APP_URL=https://your-domain.com

# ============================================
# API CONFIGURATION (Optional - if using Vercel API)
# ============================================

# Vercel API base URL
# VITE_API_BASE_URL=https://hh-asia-tyre-crm-inv-sys.vercel.app/api

# ============================================
# NOTES:
# ============================================
# 
# ⚠️ SECURITY REMINDERS:
# - NEVER share these credentials
# - NEVER commit .env to Git
# - The .gitignore file already excludes .env
# - Use anon key in frontend, NOT service_role key
# - Service role key should only be used in secure server-side code
#
# 🔧 DEVELOPMENT:
# - These variables are available in your app via: import.meta.env.VITE_*
# - Example: import.meta.env.VITE_SUPABASE_URL
#
# 🚀 PRODUCTION:
# - Set these as environment variables in your hosting provider
# - For Vercel: Project Settings → Environment Variables
#
